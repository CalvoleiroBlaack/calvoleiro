# Calvoleiro — Environment Variables
# Copie para .env.local e preencha

# ── Database ──────────────────────────────────────
# Supabase (production)
# DATABASE_URL=postgresql://postgres:SUA_SENHA@db.PROJECT.supabase.co:5432/postgres

# Pooler (Vercel / serverless – IPv4)
# DATABASE_URL=postgresql://postgres.PROJECT:SUA_SENHA@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Local Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/calvoleiro

# ── Auth ──────────────────────────────────────────
# Gere com: openssl rand -base64 48
SESSION_SECRET=change-me-generate-a-secure-random-string-min-32-chars

# ── App ───────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
